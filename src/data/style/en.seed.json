      },
      {
        "id": "commerce-and-tiktok",
        "label": "Story Commerce",
        "title": "Ready for TikTok-first product storytelling",
        "description": "Each set should support product tags, short episode ideas, CTA copy and marketplace-link placeholders without hard-selling."
      },
      {
        "id": "production-guidelines",
        "label": "Production",
        "title": "Prompt-ready, safe and scalable",
